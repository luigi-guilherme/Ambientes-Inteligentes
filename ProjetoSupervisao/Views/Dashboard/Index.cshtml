@{
    ViewData["Title"] = "Histórico de Dados";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>@ViewData["Title"]</h2>
<p>Consulta histórica de dados dos sensores</p>

<div>
    <a href="/Home/Index" class="btn btn-secondary mb-3">Voltar</a>
</div>

<fieldset class="form-group border p-3 mb-3">
    <legend class="w-auto px-2">Filtros</legend>
    <div class="row">
        <div class="col-md-5">
            <label>Dispositivo</label>
            <select id="dispositivo" class="form-control" asp-items="ViewBag.Dispositivos"></select>
        </div>
        <div class="col-md-4">
            <label>Quantidade de Registros</label>
            <input type="number" id="lastN" class="form-control" value="30" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <input type="button" id="btnFiltrar" value="Aplicar Filtro" class="btn btn-primary w-100" />
        </div>
    </div>
</fieldset>

<div id="loading" style="display: none;">
    <p class="text-center">Buscando dados...</p>
</div>

<div class="chart-container" style="position: relative; height:40vh; width:80vw">
    <canvas id="sensorChart"></canvas>
</div>

<hr />

<h3>Dados Históricos</h3>
<div id="tabelaHistorico" class="table-responsive">
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        var meuGrafico = null;

        $("#btnFiltrar").click(function () {

            var deviceId = $("#dispositivo").val();
            var lastN = $("#lastN").val();

            if (!deviceId || deviceId == "0" || !lastN || lastN <= 0) {
                alert("Por favor, selecione um dispositivo e informe a quantidade (maior que 0).");
                return;
            }

            $("#loading").show();
            $("#tabelaHistorico").html(""); // Limpa a tabela antiga
            if(meuGrafico) meuGrafico.destroy(); // Limpa o gráfico antigo

            $.ajax({
                url: "/dashboard/buscarhistorico",
                type: "GET",
                data: {
                    deviceId: deviceId,
                    lastN: lastN
                },
                success: function (dados) {
                    $("#loading").hide();
                    if (dados.erro) {
                        alert(dados.erro);
                    } else if (dados.labels.length === 0) {
                        alert("Nenhum dado encontrado para este dispositivo/período.");
                    } else {
                        //
                        // MODIFICAÇÃO: Chama as duas funções de renderização
                        //
                        renderizarGrafico(dados);
                        renderizarTabela(dados);
                    }
                },
                error: function () {
                    $("#loading").hide();
                    alert("Erro ao conectar com o servidor.");
                }
            });
        });

        // PASSO 4: Renderiza o Gráfico (Dashboard)
        function renderizarGrafico(dados) {

            if(meuGrafico) {
                meuGrafico.destroy();
            }

            const ctx = document.getElementById('sensorChart');
            meuGrafico = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: dados.labels,
                    datasets: [
                        {
                            label: 'Temperatura (ºC)',
                            data: dados.temperaturas,
                            borderColor: 'rgb(255, 99, 132)',
                            tension: 0.1
                        },
                        {
                            label: 'Umidade (%)',
                            data: dados.umidades,
                            borderColor: 'rgb(54, 162, 235)',
                            tension: 0.1
                        },
                        {
                            label: 'Luminosidade (Lux)',
                            data: dados.luminosidades,
                            borderColor: 'rgb(255, 206, 86)',
                            tension: 0.1
                        }
                    ]
                }
            });
        }

        //
        // ====================================================
        // NOVA FUNÇÃO: Renderiza a Tabela
        // ====================================================
        //
        function renderizarTabela(dados) {
            var html = '<table class="table table-striped table-sm">';
            html += '<thead><tr><th>Horário</th><th>Temperatura (ºC)</th><th>Umidade (%)</th><th>Luminosidade (Lux)</th></tr></thead>';
            html += '<tbody>';

            // Faz o loop pelos dados recebidos
            for (var i = 0; i < dados.labels.length; i++) {
                html += '<tr>';
                html += '<td>' + dados.labels[i] + '</td>';
                html += '<td>' + (dados.temperaturas[i] !== undefined ? dados.temperaturas[i] : 'N/A') + '</td>';
                html += '<td>' + (dados.umidades[i] !== undefined ? dados.umidades[i] : 'N/A') + '</td>';
                html += '<td>' + (dados.luminosidades[i] !== undefined ? dados.luminosidades[i] : 'N/A') + '</td>';
                html += '</tr>';
            }

            html += '</tbody></table>';

            // Injeta o HTML na div
            $("#tabelaHistorico").html(html);
        }
    </script>
}