@model UsuarioViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cadastro de Usuário";
}

<h2>@ViewData["Title"]</h2>

<form action="/usuario/save" method="post" class="col-md-6">

    <input type="hidden" name="Operacao" value="@ViewBag.Operacao" />
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label for="Nome" class="form-label">Nome</label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label for="Login" class="form-label">Login</label>
        <input asp-for="Login" class="form-control" />
        <span asp-validation-for="Login" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label for="Senha" class="form-label">Senha</label>
        <input asp-for="Senha" type="password" class="form-control" />
        <span asp-validation-for="Senha" class="text-danger"></span>
    </div>

    <div class="form-group">
        <input type="submit" value="Salvar Dados" class="btn btn-success" />

        @if (ViewBag.ShowBackButton == true)
        {
            @:&nbsp;
            <a href="/usuario/index" class="btn btn-secondary">Voltar</a>
        }

    </div>
</form>