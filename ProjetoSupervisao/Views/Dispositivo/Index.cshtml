@model List<DispositivoViewModel>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Listagem de Dispositivos";
}

<h2>@ViewData["Title"]</h2>

<div>
    <a href="/dispositivo/create" class="btn btn-primary mb-3">Novo Registro</a>
    <a href="/Home/Index" class="btn btn-secondary mb-3">Voltar</a>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Ações</th>
            <th>Id</th>
            <th>Nome</th>
            <th>Local</th>
            <th>ID FIWARE</th>
            <th>Foto</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var dispositivo in Model)
        {
            <tr>
                <td>
                    <a href="/dispositivo/edit?id=@dispositivo.Id" class="btn btn-sm btn-info">Editar</a>
                    <a href="javascript:confirmarExclusao(@dispositivo.Id)" class="btn btn-sm btn-danger">Apagar</a>
                </td>
                <td>@dispositivo.Id</td>
                <td>@dispositivo.Nome</td>
                <td>@dispositivo.NomeLocal</td>
                <td>@dispositivo.Device_Id_FIWARE</td>
                <td>
                    @if (!string.IsNullOrEmpty(dispositivo.ImagemEmBase64))
                    {
                        <img src="data:image/jpeg;base64,@dispositivo.ImagemEmBase64" style="width: 60px; height: 60px; object-fit: cover;" />
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
    function confirmarExclusao(id) {
        Swal.fire({
            title: 'Tem certeza?',
            text: "Essa ação não poderá ser desfeita!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Sim, apagar!',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/dispositivo/delete?id=' + id;
            }
        });
    }
</script>