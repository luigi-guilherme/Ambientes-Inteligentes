@model LocalViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cadastro de Local";
}

<h2>@ViewData["Title"]</h2>

<form action="/local/save" method="post" class="col-md-6">

    <input type="hidden" name="Operacao" value="@ViewBag.Operacao" />

    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label for="Nome" class="form-label">Nome</label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label for="Descricao" class="form-label">Descrição</label>
        <input asp-for="Descricao" class="form-control" />
        <span asp-validation-for="Descricao" class="text-danger"></span>
    </div>

    <div class="form-group">
        <input type="submit" value="Salvar Dados" class="btn btn-success" />
        &nbsp;
        <a href="/local/index" class="btn btn-secondary">Voltar</a>
    </div>
</form>