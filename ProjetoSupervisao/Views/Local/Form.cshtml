@model LocalViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cadastro de Local";
}

<h2>@ViewData["Title"]</h2>

<form action="/local/save" method="post" class="col-md-6">

    <input type="hidden" name="Operacao" value="@ViewBag.Operacao" />

    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label for="Nome" class="form-label">Nome</label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label for="Descricao" class="form-label">Descrição</label>
        <input asp-for="Descricao" class="form-control" />
        <span asp-validation-for="Descricao" class="text-danger"></span>
    </div>

    <fieldset class="form-group border p-3 mb-3">
        <legend class="w-auto px-2">Limites de Alerta (Triggers)</legend>
        
        <div class="row">
            <div class="col-md-4">
                <label for="TempMin" class="form-label">Temperatura Mín. (°C)</label>
                <input asp-for="TempMin" class="form-control" step="0.1" />
            </div>
            <div class="col-md-4">
                <label for="TempMax" class="form-label">Temperatura Máx. (°C)</label>
                <input asp-for="TempMax" class="form-control" step="0.1" />
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-4">
                <label for="UmidadeMin" class="form-label">Umidade Mín. (%)</label>
                <input asp-for="UmidadeMin" class="form-control" step="0.1" />
            </div>
            <div class="col-md-4">
                <label for="UmidadeMax" class="form-label">Umidade Máx. (%)</label>
                <input asp-for="UmidadeMax" class="form-control" step="0.1" />
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-4">
                <label for="LuminosidadeMin" class="form-label">Luminosidade Mín. (Lux)</label>
                <input asp-for="LuminosidadeMin" class="form-control" step="0.1" />
            </div>
            <div class="col-md-4">
                <label for="LuminosidadeMax" class="form-label">Luminosidade Máx. (Lux)</label>
                <input asp-for="LuminosidadeMax" class="form-control" step="0.1" />
            </div>
        </div>
    </fieldset>

    <div class="form-group">
        <input type="submit" value="Salvar Dados" class="btn btn-success" />
        &nbsp;
        <a href="/local/index" class="btn btn-secondary">Voltar</a>
    </div>
</form>